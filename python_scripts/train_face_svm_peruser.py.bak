import cv2
import os
import sys
import json
import numpy as np
import joblib
from sklearn.svm import SVC
from sklearn.preprocessing import StandardScaler

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from lbp_features import extract_lbp_features, FACE_SIZE

MAX_NEGATIVE_PER_USER = 10
MAX_TOTAL_NEGATIVES = 200


def augment_image(image):
    augmented = []

    flipped = cv2.flip(image, 1)
    augmented.append(flipped)

    bright_factor = np.random.uniform(0.7, 1.3)
    bright = np.clip(
        image.astype(np.float32) * bright_factor, 0, 255
    ).astype(np.uint8)
    augmented.append(bright)

    return augmented


def load_images(dataset_path):
    valid_ext = ('.jpg', '.jpeg', '.png')
    images = []

    if not os.path.exists(dataset_path):
        return images

    files = sorted([
        f for f in os.listdir(dataset_path)
        if f.lower().endswith(valid_ext)
    ])

    for filename in files:
        filepath = os.path.join(dataset_path, filename)
        img = cv2.imread(filepath, cv2.IMREAD_GRAYSCALE)
        if img is not None:
            img = cv2.resize(img, FACE_SIZE, interpolation=cv2.INTER_AREA)
            images.append(img)

    return images


def load_negative_samples(base_datasets_path, exclude_user_id):
    negative_images = []

    if not os.path.exists(base_datasets_path):
        return negative_images

    for folder_name in os.listdir(base_datasets_path):
        if folder_name == str(exclude_user_id):
            continue

        folder_path = os.path.join(base_datasets_path, folder_name)
        if not os.path.isdir(folder_path):
            continue

        user_images = load_images(folder_path)
        if user_images:
            if len(user_images) > MAX_NEGATIVE_PER_USER:
                indices = np.linspace(
                    0, len(user_images) - 1,
                    MAX_NEGATIVE_PER_USER, dtype=int
                )
                user_images = [user_images[i] for i in indices]
            negative_images.extend(user_images)

        if len(negative_images) >= MAX_TOTAL_NEGATIVES:
            negative_images = negative_images[:MAX_TOTAL_NEGATIVES]
            break

    return negative_images


def generate_identity_negatives(positive_images, num_samples):
    negatives = []
    n_pos = len(positive_images)
    if n_pos == 0:
        return negatives

    for i in range(num_samples):
        method = i % 5

        base_img = positive_images[i % n_pos].copy()
        h, w = base_img.shape

        if method == 0:
            grid = 4
            bh, bw = h // grid, w // grid
            patches = []
            for gy in range(grid):
                for gx in range(grid):
                    patch = base_img[gy*bh:(gy+1)*bh, gx*bw:(gx+1)*bw].copy()
                    patches.append(patch)
            np.random.shuffle(patches)
            result = np.zeros_like(base_img)
            idx = 0
            for gy in range(grid):
                for gx in range(grid):
                    result[gy*bh:(gy+1)*bh, gx*bw:(gx+1)*bw] = patches[idx]
                    idx += 1
            negatives.append(result)

        elif method == 1:
            img1 = positive_images[i % n_pos]
            img2 = positive_images[(i + n_pos // 2) % n_pos]
            alpha = np.random.uniform(0.3, 0.7)
            blended = cv2.addWeighted(img1, alpha, img2, 1 - alpha, 0)
            mid = h // 2
            result = blended.copy()
            result[:mid, :] = cv2.flip(result[:mid, :], 1)
            result[mid:, :] = cv2.flip(result[mid:, :], 0)
            negatives.append(result)

        elif method == 2:
            result = base_img.copy()
            cx, cy = w // 2, h // 2
            angle = np.random.choice([90, 180, 270])
            M = cv2.getRotationMatrix2D((cx, cy), angle, 0.8)
            result = cv2.warpAffine(result, M, (w, h),
                                    borderMode=cv2.BORDER_REFLECT)
            noise = np.random.normal(0, 25, result.shape).astype(np.float32)
            result = np.clip(result.astype(np.float32) + noise, 0, 255).astype(np.uint8)
            negatives.append(result)

        elif method == 3:
            result = base_img.copy()
            strip_h = h // 6
            indices = list(range(6))
            np.random.shuffle(indices)
            shuffled = np.zeros_like(result)
            for j, src_idx in enumerate(indices):
                src_start = src_idx * strip_h
                dst_start = j * strip_h
                src_end = min(src_start + strip_h, h)
                dst_end = min(dst_start + strip_h, h)
                copy_h = min(src_end - src_start, dst_end - dst_start)
                shuffled[dst_start:dst_start+copy_h, :] = result[src_start:src_start+copy_h, :]
            if np.random.random() > 0.5:
                shuffled = cv2.flip(shuffled, -1)
            negatives.append(shuffled)

        elif method == 4:
            result = base_img.copy()
            result = cv2.flip(result, -1)
            gamma = np.random.choice([0.3, 0.5, 2.0, 3.0])
            table = np.array([
                ((i / 255.0) ** gamma) * 255
                for i in np.arange(256)
            ]).astype("uint8")
            result = cv2.LUT(result, table)
            kernel_size = np.random.choice([7, 11, 15])
            result = cv2.GaussianBlur(result, (kernel_size, kernel_size), 0)
            negatives.append(result)

    return negatives


def generate_pure_noise_negatives(num_samples):
    negatives = []
    for _ in range(num_samples):
        noise = np.random.randint(0, 256, FACE_SIZE, dtype=np.uint8)
        noise = cv2.GaussianBlur(noise, (7, 7), 0)
        negatives.append(noise)
    return negatives


def train_model(user_id, dataset_path, model_output_path,
                base_datasets_path=None):
    try:
        if not os.path.exists(dataset_path):
            raise Exception(f"Dataset path tidak ditemukan: {dataset_path}")

        images = load_images(dataset_path)

        if len(images) == 0:
            raise Exception(
                "Tidak ada gambar valid ditemukan di folder dataset."
            )

        if len(images) < 10:
            raise Exception(
                f"Jumlah gambar terlalu sedikit ({len(images)}). "
                "Minimal dibutuhkan 10 gambar untuk training yang baik."
            )

        X_positive = []
        for img in images:
            features = extract_lbp_features(img)
            X_positive.append(features)

            for aug_img in augment_image(img):
                aug_features = extract_lbp_features(aug_img)
                X_positive.append(aug_features)

        X_negative = []
        negative_source = "none"

        if base_datasets_path and os.path.exists(base_datasets_path):
            neg_images = load_negative_samples(
                base_datasets_path, user_id
            )
            if len(neg_images) > 0:
                negative_source = (
                    f"other_users ({len(neg_images)} frames)"
                )
                for neg_img in neg_images:
                    features = extract_lbp_features(neg_img)
                    X_negative.append(features)

                    for aug_img in augment_image(neg_img):
                        aug_features = extract_lbp_features(aug_img)
                        X_negative.append(aug_features)

        identity_neg_count = max(len(X_positive), 50)
        identity_negatives = generate_identity_negatives(images, identity_neg_count)
        for neg_img in identity_negatives:
            features = extract_lbp_features(neg_img)
            X_negative.append(features)

        noise_count = max(len(X_positive) // 3, 15)
        noise_negatives = generate_pure_noise_negatives(noise_count)
        for neg_img in noise_negatives:
            features = extract_lbp_features(neg_img)
            X_negative.append(features)

        neg_src_parts = []
        if "other_users" in negative_source:
            neg_src_parts.append(negative_source)
        neg_src_parts.append(f"identity_shuffle ({len(identity_negatives)})")
        neg_src_parts.append(f"noise ({len(noise_negatives)})")
        negative_source = " + ".join(neg_src_parts)

        if len(X_negative) > len(X_positive) * 3:
            indices = np.linspace(
                0, len(X_negative) - 1,
                len(X_positive) * 3, dtype=int
            )
            X_negative = [X_negative[i] for i in indices]

        y_positive = [1] * len(X_positive)
        y_negative = [0] * len(X_negative)

        X = np.array(X_positive + X_negative)
        y = np.array(y_positive + y_negative)

        scaler = StandardScaler()
        X_scaled = scaler.fit_transform(X)

        svm = SVC(
            kernel='rbf',
            C=10,
            gamma='scale',
            probability=True,
            class_weight='balanced',
            random_state=42
        )
        svm.fit(X_scaled, y)

        positive_features = np.array(X_positive)
        centroid = np.mean(positive_features, axis=0)
        std_dev = np.std(positive_features, axis=0) + 1e-8
        distances = np.array([
            np.sqrt(np.sum(((f - centroid) / std_dev) ** 2))
            for f in positive_features
        ])
        max_distance = float(np.percentile(distances, 95))

        if not os.path.exists(model_output_path):
            os.makedirs(model_output_path)

        model_file = os.path.join(
            model_output_path, f"user_{user_id}_svm.pkl"
        )
        scaler_file = os.path.join(
            model_output_path, f"user_{user_id}_scaler.pkl"
        )
        centroid_file = os.path.join(
            model_output_path, f"user_{user_id}_centroid.pkl"
        )

        joblib.dump(svm, model_file)
        joblib.dump(scaler, scaler_file)
        joblib.dump({
            'centroid': centroid,
            'std_dev': std_dev,
            'max_distance': max_distance,
        }, centroid_file)

        print(json.dumps({
            "status": "success",
            "message": (
                f"Model SVM berhasil dilatih dengan {len(X_positive)} "
                f"sampel positif dan {len(X_negative)} sampel negatif"
            ),
            "samples_positive": len(X_positive),
            "samples_negative": len(X_negative),
            "negative_source": negative_source,
            "total_samples": len(X),
            "feature_dimension": X.shape[1],
            "max_distance_threshold": round(max_distance, 2),
            "model_path": model_file,
            "scaler_path": scaler_file,
            "centroid_path": centroid_file
        }))

    except Exception as e:
        print(json.dumps({
            "status": "error",
            "message": str(e)
        }))
        sys.exit(1)


if __name__ == "__main__":
    if len(sys.argv) < 4:
        print(json.dumps({
            "status": "error",
            "message": (
                "Usage: python train_face_svm.py <user_id> "
                "<dataset_path> <model_output_path> [base_datasets_path]"
            )
        }))
        sys.exit(1)

    u_id = sys.argv[1]
    d_path = sys.argv[2]
    m_path = sys.argv[3]
    b_path = sys.argv[4] if len(sys.argv) > 4 else None

    train_model(u_id, d_path, m_path, b_path)
